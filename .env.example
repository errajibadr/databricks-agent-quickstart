# Copy this file to `.env` and fill in your values.
# `.env` is gitignored.

# === Databricks auth ===
# Option A (recommended): use a Databricks CLI profile.
# Configure once with: `databricks auth login --profile DEFAULT`
# The Databricks SDK picks this up automatically.
DATABRICKS_CONFIG_PROFILE=DEFAULT

# Option B: explicit host + token (overrides the profile if both are set).
# DATABRICKS_HOST=https://adb-XXXXXXXXXX.azuredatabricks.net
# DATABRICKS_TOKEN=dapi...

# === Agent config (matches 03_agent.py env-var contract) ===

# Required — workspace-specific. Format: catalog.schema.index_name
VS_INDEX=your_catalog.your_schema.docs_index

# Optional — default to Databricks Foundation Model APIs (system endpoints).
# Override only if you want to point at a different model serving endpoint.
# LLM_ENDPOINT=databricks-gpt-oss-120b
# EMBEDDING_ENDPOINT=databricks-gte-large-en

# Optional — system prompt override.
# SYSTEM_PROMPT="You are a helpful assistant..."
