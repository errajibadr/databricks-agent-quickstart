# --- Backend selection -------------------------------------------------------
# local    = import a ResponsesAgent module in-process (Lane L1, this Step A)
# endpoint = call a deployed Serving Endpoint via AsyncDatabricksOpenAI (Step B)
BACKEND=local

# --- Lane L1: LocalAgentBackend ---------------------------------------------
# Path to a Python file that exposes a module-level `AGENT` (a ResponsesAgent).
# Default points at databricks-agent-quickstart/03_agent.py (sibling dir).
LOCAL_AGENT_MODULE=../03_agent.py

# --- 03_agent.py runtime config (REQUIRED) ----------------------------------
# Vector Search index for the `search_docs` tool. No default — fail loud.
VS_INDEX=your_catalog.your_schema.docs_index

# Optional 03_agent.py overrides:
# LLM_ENDPOINT=databricks-gpt-oss-120b
# EMBEDDING_ENDPOINT=databricks-gte-large-en

# --- Databricks authentication (pick ONE of three patterns) -----------------
# Both backends resolve auth via WorkspaceClient — which walks the standard
# Databricks unified auth chain. You almost certainly DON'T need to set
# DATABRICKS_HOST/TOKEN here if you've already configured a profile.
#
# Pattern A — DEFAULT profile (recommended; nothing to set here):
#   Run `databricks configure` once → ~/.databrickscfg gets a [DEFAULT] block.
#   WorkspaceClient() finds it automatically. Leave the vars below commented.
#
# Pattern B — Named profile (when DEFAULT is wrong workspace):
# DATABRICKS_CONFIG_PROFILE=my-workspace-profile
#
# Pattern C — Explicit host + PAT (headless / Apps / CI contexts):
# DATABRICKS_HOST=https://<workspace>.cloud.databricks.com
# DATABRICKS_TOKEN=dapi...

# --- Lane L2/L3/L4: EndpointBackend -----------------------------------------
# Name of the Serving Endpoint deployed in your workspace (NOT the model
# registry name). Required when BACKEND=endpoint; ignored when BACKEND=local.
#
# Auth: EndpointBackend.from_env() builds a WorkspaceClient via the standard
# Databricks auth chain. Same three patterns as the block above —
#   Pattern A (DEFAULT profile, recommended for local dev): set nothing here.
#   Pattern B (named profile): set DATABRICKS_CONFIG_PROFILE.
#   Pattern C (explicit PAT, headless / Apps OBO): set DATABRICKS_HOST + TOKEN.
# Lane L3 (Apps OBO): the Apps handler will pass `obo_token=` from the
# `x-forwarded-access-token` request header — no config needed here.
ENDPOINT_NAME=doc-agent-quickstart

# Auth mode for the serving-endpoint call (Lane L3 only — local dev always
# uses the SDK auth chain).
#   obo (default) → per-user identity via `x-forwarded-access-token`.
#   sp            → App service principal credentials. Use when sessions
#                   need to outlive the OBO TTL (~60min on Azure Databricks)
#                   without losing Chainlit chat history. Trade-off: audit
#                   shows the App SP, not the user, and every backend
#                   endpoint / sub-agent needs `CAN_QUERY` granted to the
#                   App SP separately.
# BACKEND_AUTH=obo
