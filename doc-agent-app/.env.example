# Databricks authentication (local dev — auto-injected when deployed)
DATABRICKS_CONFIG_PROFILE=DEFAULT

# Agent configuration — edit these to match your workspace
VS_INDEX=my_catalog.agent_lab.docs_index

# LLM endpoint.
# IMPORTANT: pick a model that supports token-level streaming with tools bound.
# See ../experiments/streaming/README.md for the full investigation. TL;DR:
#   ✅ databricks-meta-llama-3-3-70b-instruct  — streams token-by-token with tools
#   ❌ databricks-gpt-oss-120b                  — collapses to one chunk with tools
#   ❌ databricks-llama-4-maverick              — collapses to one chunk with tools
# gpt-oss-120b still works functionally (you get the final answer), but the
# typewriter UX requires a streaming-capable model.
LLM_ENDPOINT=databricks-meta-llama-3-3-70b-instruct

EMBEDDING_ENDPOINT=databricks-gte-large-en

# MLflow experiment (created by quickstart or manually)
MLFLOW_EXPERIMENT_ID=
